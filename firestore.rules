rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    /**
     * @description This ruleset enforces a role-based access control model.
     *              It allows users to read incident reports but restricts modification to administrators.
     * @dataStructure /users/{userId} stores user profiles with roles; /incidentReports/{incidentReportId} stores incident reports.
     * @keySecurityDecisions Only admins can create, update, or delete incident reports.
     *                        Users can only read incident reports. User listing is denied.
     */

    // Helper function to check if the user is signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper function to check if the user is an admin
    function isAdmin() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Helper function to check if the user is the owner of a document
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Manages user profile data, allowing users to read and write their own profiles.
     * @path /users/{userId}
     * @allow (create) - User 'abc' can create their profile if authenticated as 'abc'.
     * @allow (get) - User 'abc' can read their own profile if authenticated as 'abc'.
     * @allow (update) - User 'abc' can update their profile if authenticated as 'abc'.
     * @deny (create) - User 'def' cannot create a profile for user 'abc'.
     * @deny (update) - User 'def' cannot update the profile of user 'abc'.
     * @principle Enforces document ownership for writes, allowing users to manage their own data.
     */
    match /users/{userId} {
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow get: if isOwner(userId);
      allow update: if isOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if false; // Deletion not allowed in this phase.
      allow list: if false; // Disable user listing
    }

    /**
     * @description Manages incident reports, allowing public read access but restricting modifications to admins.
     * @path /incidentReports/{incidentReportId}
     * @allow (get) - Any user can read an incident report.
     * @allow (list) - Any user can list incident reports.
     * @allow (create) - Admin user 'admin_abc' can create a new incident report.
     * @allow (update) - Admin user 'admin_abc' can update an existing incident report.
     * @allow (delete) - Admin user 'admin_abc' can delete an existing incident report.
     * @deny (create) - Regular user cannot create an incident report.
     * @deny (update) - Regular user cannot update an incident report.
     * @deny (delete) - Regular user cannot delete an incident report.
     * @principle Allows public read access with owner-only (admin) writes.
     */
    match /incidentReports/{incidentReportId} {
      allow get: if true;
      allow list: if true;
      allow create: if isAdmin();
      allow update: if isAdmin() && resource != null;
      allow delete: if isAdmin() && resource != null;
    }
  }
}